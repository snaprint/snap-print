# Snap Print Environment Variables
# Copy this file to .env and fill in your values

# ── Google Sheets (Published CSV URLs) ──
# Publish your sheets as CSV: File → Share → Publish to web → CSV
VITE_PRODUCTS_CSV_URL=
VITE_SHIPPING_RATES_CSV_URL=

# ── Razorpay ──
# Get keys from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Razorpay Webhook ──
# Create at https://dashboard.razorpay.com/app/webhooks
# Event: payment.captured
# URL: https://your-domain.pages.dev/api/webhook
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend.com — free tier: 3000 emails/month) ──
# Sign up at https://resend.com
RESEND_API_KEY=
SELLER_EMAIL=hello@snaprint.in

# ── Google Sheets Logging (Orders Sheet) ──
# Optional: to log paid orders to a Google Sheet
# Create a service account and share the sheet with it
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=

# ── Cloudflare Turnstile (optional, bot protection) ──
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
